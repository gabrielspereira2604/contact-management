@model ContactManagement.Models.Contact
@{
    ViewData["Title"] = "Contact Details";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Contact Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4 text-muted">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                </dl>
            </div>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark btn-sm">Edit</a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                            onclick="return confirm('Delete this contact?')">Delete</button>
                    </form>
                </div>
            }
        </div>
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>
    </div>
</div>
